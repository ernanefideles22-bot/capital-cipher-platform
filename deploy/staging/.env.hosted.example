# Reference only. Store the three secret values below in the deployment
# provider's secret manager; do not copy this file to a public host unchanged.
# Passwords must be URL-encoded inside connection URLs.
DATABASE_URL=postgresql+asyncpg://capital_cipher_staging.phkligpkcitbbefrrotk:REPLACE_WITH_RUNTIME_ROLE_PASSWORD@aws-0-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=verify-full&sslrootcert=/run/secrets/supabase-ca.crt
REDIS_URL=rediss://default:REPLACE_WITH_REDIS_PASSWORD@REPLACE_WITH_REDIS_HOST:6379/0
ADMIN_API_KEY=REPLACE_WITH_32_PLUS_RANDOM_URL_SAFE_CHARACTERS
SUPABASE_CA_CERT_HOST_PATH=REPLACE_WITH_ABSOLUTE_PATH_TO_SUPABASE_CA_CERTIFICATE

# Non-secret pins. The Redis host must exactly match the host in REDIS_URL.
STAGING_EXPECTED_REDIS_HOST=REPLACE_WITH_REDIS_HOST
# Leave empty for rediss://. Use FLY_6PN only for Fly's organization-private
# fly-*.upstash.io endpoint, which is carried over Fly's WireGuard 6PN.
STAGING_REDIS_PRIVATE_NETWORK=
STAGING_CORS_ALLOWED_ORIGINS=https://REPLACE_WITH_STAGING_HOST
STAGING_BACKEND_PORT=8000

# Bound the persistent SQLAlchemy pool for the Supabase Free staging database.
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=0
DATABASE_POOL_TIMEOUT_SECONDS=15
DATABASE_POOL_RECYCLE_SECONDS=300

# Bounded PAPER workload. No exchange credential belongs in this file.
ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
DEFAULT_TIMEFRAME=15m
AGENT_MAX_CONCURRENCY=8
AGENT_WORKER_BATCH_SIZE=4
AGENT_EXECUTION_UNIT_COST_USD=0
OPERATIONS_DAILY_BUDGET_USD=10
RISK_PER_TRADE_PERCENT=0.25
MAX_DAILY_DRAWDOWN_PERCENT=2
MAX_TOTAL_DRAWDOWN_PERCENT=5
MAX_OPEN_POSITIONS=3
API_RATE_LIMIT_PER_MINUTE=300
LOG_LEVEL=INFO

STAGING_WATCHDOG_INTERVAL_SECONDS=30
STAGING_WATCHDOG_FAILURE_THRESHOLD=3
