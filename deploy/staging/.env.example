# Copy to deploy/staging/.env and replace every placeholder with a new,
# URL-safe random value. The preflight rejects placeholders and weak secrets.
STAGING_POSTGRES_PASSWORD=REPLACE_WITH_32_PLUS_RANDOM_URL_SAFE_CHARACTERS
STAGING_REDIS_PASSWORD=REPLACE_WITH_32_PLUS_RANDOM_URL_SAFE_CHARACTERS
ADMIN_API_KEY=REPLACE_WITH_32_PLUS_RANDOM_URL_SAFE_CHARACTERS

# The API is bound to loopback. Put an authenticated TLS reverse proxy in
# front of it before allowing access from another machine.
STAGING_BACKEND_PORT=8000
STAGING_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173

# Bounded PAPER workload. No exchange credential belongs in this file.
ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
DEFAULT_TIMEFRAME=15m
AGENT_MAX_CONCURRENCY=8
AGENT_WORKER_BATCH_SIZE=4
AGENT_EXECUTION_UNIT_COST_USD=0
OPERATIONS_DAILY_BUDGET_USD=10
RISK_PER_TRADE_PERCENT=0.25
MAX_DAILY_DRAWDOWN_PERCENT=2
MAX_TOTAL_DRAWDOWN_PERCENT=5
MAX_OPEN_POSITIONS=3
API_RATE_LIMIT_PER_MINUTE=300
LOG_LEVEL=INFO

# Three consecutive failed probes terminate the watchdog container.
STAGING_WATCHDOG_INTERVAL_SECONDS=30
STAGING_WATCHDOG_FAILURE_THRESHOLD=3
