{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.capital-cipher.local/v1/historical-execution-dataset.schema.json",
  "title": "Capital Cipher Historical Execution Dataset v1",
  "type": "object",
  "required": [
    "schema_version",
    "dataset_version",
    "source",
    "exchange",
    "symbol",
    "max_age_seconds",
    "observations"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "dataset_version": {"const": "historical-execution-v1"},
    "source": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]+$"
    },
    "exchange": {"enum": ["BINANCE", "BYBIT"]},
    "symbol": {
      "type": "string",
      "pattern": "^[A-Z0-9._-]{2,32}$"
    },
    "max_age_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 604800
    },
    "observations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000000,
      "items": {
        "type": "object",
        "required": [
          "observed_at",
          "half_spread_bps",
          "funding_rate_bps_per_8h",
          "source_record_id"
        ],
        "properties": {
          "observed_at": {"type": "string", "format": "date-time"},
          "half_spread_bps": {
            "type": "number",
            "minimum": 0,
            "maximum": 1000
          },
          "funding_rate_bps_per_8h": {
            "type": "number",
            "minimum": -1000,
            "maximum": 1000
          },
          "source_record_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
