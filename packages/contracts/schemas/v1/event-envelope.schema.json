{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.capital-cipher.local/v1/event-envelope.schema.json",
  "title": "Capital Cipher Event Envelope v1",
  "type": "object",
  "required": [
    "message_id",
    "event_id",
    "correlation_id",
    "topic",
    "event_type",
    "source",
    "timestamp",
    "schema_version",
    "payload"
  ],
  "properties": {
    "message_id": {
      "type": "string",
      "minLength": 1
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "topic": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]+\\.v[1-9][0-9]*$"
    },
    "event_type": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]+$"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "payload": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
