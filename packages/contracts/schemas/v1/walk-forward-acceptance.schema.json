{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.capital-cipher.local/v1/walk-forward-acceptance.schema.json",
  "title": "Capital Cipher Walk-Forward Acceptance Criteria v1",
  "type": "object",
  "required": [
    "schema_version",
    "gate_version",
    "minimum_folds",
    "minimum_trades",
    "minimum_profitable_fold_ratio",
    "minimum_median_net_pnl_percent",
    "minimum_mean_expectancy",
    "maximum_worst_drawdown_percent",
    "require_zero_liquidations"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "gate_version": {"const": "walk-forward-gate-v1"},
    "minimum_folds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "minimum_trades": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000000
    },
    "minimum_profitable_fold_ratio": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "minimum_median_net_pnl_percent": {"type": "number"},
    "minimum_mean_expectancy": {"type": "number"},
    "maximum_worst_drawdown_percent": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 100
    },
    "require_zero_liquidations": {"type": "boolean"}
  },
  "additionalProperties": false
}
