{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.capital-cipher.local/v1/drift-observation.schema.json",
  "title": "DriftObservationV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "observation_id", "experiment_id", "agent_name",
    "agent_version", "reference_samples", "current_samples",
    "reference_accuracy", "current_accuracy", "accuracy_delta",
    "reference_brier_loss", "current_brier_loss", "brier_delta",
    "reference_marginal_contribution", "current_marginal_contribution",
    "marginal_delta", "severity", "reasons", "observed_at", "created_at"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "observation_id": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "experiment_id": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "agent_name": { "type": "string", "minLength": 3, "maxLength": 128 },
    "agent_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "reference_samples": { "type": "integer", "minimum": 30 },
    "current_samples": { "type": "integer", "minimum": 10 },
    "reference_accuracy": { "$ref": "#/$defs/nullable_unit" },
    "current_accuracy": { "$ref": "#/$defs/nullable_unit" },
    "accuracy_delta": { "$ref": "#/$defs/nullable_delta" },
    "reference_brier_loss": { "type": "number", "minimum": 0, "maximum": 1 },
    "current_brier_loss": { "type": "number", "minimum": 0, "maximum": 1 },
    "brier_delta": { "type": "number", "minimum": -1, "maximum": 1 },
    "reference_marginal_contribution": { "type": "number", "minimum": -1, "maximum": 1 },
    "current_marginal_contribution": { "type": "number", "minimum": -1, "maximum": 1 },
    "marginal_delta": { "type": "number", "minimum": -2, "maximum": 2 },
    "severity": { "enum": ["NONE", "WARNING", "CRITICAL"] },
    "reasons": { "type": "array", "items": { "type": "string" } },
    "observed_at": { "type": "string", "format": "date-time" },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "nullable_unit": {
      "anyOf": [
        { "type": "number", "minimum": 0, "maximum": 1 },
        { "type": "null" }
      ]
    },
    "nullable_delta": {
      "anyOf": [
        { "type": "number", "minimum": -1, "maximum": 1 },
        { "type": "null" }
      ]
    }
  }
}
