{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.capital-cipher.local/v1/clock-observation.schema.json",
  "title": "Capital Cipher Clock Observation v1",
  "type": "object",
  "required": [
    "schema_version",
    "observation_id",
    "source",
    "request_started_at",
    "source_at",
    "response_received_at",
    "offset_ms",
    "round_trip_ms",
    "status",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "observation_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "source": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
    },
    "request_started_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_at": {
      "type": "string",
      "format": "date-time"
    },
    "response_received_at": {
      "type": "string",
      "format": "date-time"
    },
    "offset_ms": {
      "type": "number"
    },
    "round_trip_ms": {
      "type": "number",
      "minimum": 0
    },
    "status": {
      "enum": ["SYNCED", "WARNING", "UNSAFE"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
