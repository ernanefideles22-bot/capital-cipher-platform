{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://capital-cipher.local/contracts/v1/venue-balance-snapshot.schema.json",
  "title": "VenueBalanceSnapshotV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "exchange", "environment", "asset", "available",
    "locked", "equity", "observed_at"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "exchange": { "enum": ["BINANCE", "BYBIT"] },
    "environment": { "enum": ["PAPER", "TESTNET"] },
    "asset": { "type": "string", "minLength": 1 },
    "available": { "type": "number", "minimum": 0 },
    "locked": { "type": "number", "minimum": 0 },
    "equity": { "type": "number", "minimum": 0 },
    "observed_at": { "type": "string", "format": "date-time" }
  }
}
