{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://capital-cipher.local/contracts/v1/reconciliation-mismatch.schema.json",
  "title": "ReconciliationMismatchV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "mismatch_id", "run_id", "mismatch_type",
    "severity", "exchange", "environment", "oms_order_id",
    "venue_order_id", "symbol", "expected", "observed", "created_at"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "mismatch_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "mismatch_type": {
      "enum": [
        "LOCAL_ORDER_MISSING_AT_VENUE", "ORPHAN_VENUE_ORDER",
        "ORPHAN_VENUE_FILL",
        "ORDER_STATUS_DRIFT", "FILLED_QUANTITY_DRIFT",
        "POSITION_QUANTITY_DRIFT", "ADAPTER_UNAVAILABLE"
      ]
    },
    "severity": { "enum": ["INFO", "WARNING", "CRITICAL"] },
    "exchange": { "enum": ["BINANCE", "BYBIT"] },
    "environment": { "enum": ["PAPER", "TESTNET"] },
    "oms_order_id": { "type": ["string", "null"] },
    "venue_order_id": { "type": ["string", "null"] },
    "symbol": { "type": ["string", "null"] },
    "expected": { "type": "object" },
    "observed": { "type": "object" },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
