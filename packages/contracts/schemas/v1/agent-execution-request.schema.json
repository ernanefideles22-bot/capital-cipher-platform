{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.capital-cipher.local/v1/agent-execution-request.schema.json",
  "title": "Capital Cipher Agent Execution Request v1",
  "type": "object",
  "required": [
    "schema_version",
    "runtime_version",
    "execution_mode",
    "agent_version",
    "idempotency_key",
    "input"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "runtime_version": {"const": "agent-runtime-v1"},
    "execution_mode": {"const": "PAPER"},
    "agent_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "idempotency_key": {"type": "string", "minLength": 1, "maxLength": 256},
    "input": {"$ref": "agent-input.schema.json"}
  },
  "additionalProperties": false
}
