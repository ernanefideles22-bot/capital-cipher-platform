{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://capital-cipher.local/contracts/v1/venue-position-snapshot.schema.json",
  "title": "VenuePositionSnapshotV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "exchange", "environment", "symbol", "side",
    "quantity", "entry_price", "mark_price", "unrealized_pnl",
    "observed_at"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "exchange": { "enum": ["BINANCE", "BYBIT"] },
    "environment": { "enum": ["PAPER", "TESTNET"] },
    "symbol": { "type": "string", "minLength": 1 },
    "side": { "enum": ["BUY", "SELL"] },
    "quantity": { "type": "number", "minimum": 0 },
    "entry_price": { "type": ["number", "null"], "minimum": 0 },
    "mark_price": { "type": ["number", "null"], "minimum": 0 },
    "unrealized_pnl": { "type": "number" },
    "observed_at": { "type": "string", "format": "date-time" }
  }
}
