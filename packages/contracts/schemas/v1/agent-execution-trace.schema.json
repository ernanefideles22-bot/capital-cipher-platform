{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.capital-cipher.local/v1/agent-execution-trace.schema.json",
  "title": "Capital Cipher Agent Execution Trace v1",
  "type": "object",
  "required": ["schema_version", "job", "attempts", "memory"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "job": {"$ref": "agent-execution-job.schema.json"},
    "attempts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "execution_id",
          "attempt_number",
          "worker_id",
          "status",
          "output",
          "retryable",
          "started_at",
          "completed_at"
        ],
        "properties": {
          "schema_version": {"const": "1.0.0"},
          "execution_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "attempt_number": {"type": "integer", "minimum": 1, "maximum": 10},
          "worker_id": {"type": "string", "minLength": 1, "maxLength": 128},
          "status": {
            "enum": ["COMPLETED", "FAILED", "TIMEOUT", "SKIPPED", "BLOCKED"]
          },
          "output": {"$ref": "agent-output.schema.json"},
          "retryable": {"type": "boolean"},
          "started_at": {"type": "string", "format": "date-time"},
          "completed_at": {"type": "string", "format": "date-time"}
        },
        "additionalProperties": false
      }
    },
    "memory": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "execution_id",
          "sequence",
          "entry_type",
          "payload",
          "payload_hash",
          "created_at"
        ],
        "properties": {
          "schema_version": {"const": "1.0.0"},
          "execution_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "sequence": {"type": "integer", "minimum": 1},
          "entry_type": {
            "enum": ["INPUT", "ATTEMPT", "OUTPUT", "DEAD_LETTER"]
          },
          "payload": {"type": "object"},
          "payload_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "created_at": {"type": "string", "format": "date-time"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
