{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.capital-cipher.local/v1/backfill-queue-item.schema.json",
  "title": "Capital Cipher Backfill Queue Item v1",
  "type": "object",
  "required": [
    "schema_version",
    "queue_id",
    "job_id",
    "exchange",
    "symbol",
    "timeframe",
    "start_at",
    "end_at",
    "max_candles",
    "status",
    "attempt_count",
    "max_attempts",
    "available_at",
    "leased_by",
    "lease_expires_at",
    "last_error_code",
    "last_error_message",
    "created_at",
    "updated_at",
    "completed_at"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "queue_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "job_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "exchange": {"enum": ["BINANCE", "BYBIT"]},
    "symbol": {
      "type": "string",
      "pattern": "^[A-Z0-9._-]{2,32}$"
    },
    "timeframe": {
      "type": "string",
      "pattern": "^[1-9][0-9]*[mhdw]$"
    },
    "start_at": {"type": "string", "format": "date-time"},
    "end_at": {"type": "string", "format": "date-time"},
    "max_candles": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000000
    },
    "status": {
      "enum": ["PENDING", "LEASED", "RETRY", "COMPLETED", "DEAD_LETTER"]
    },
    "attempt_count": {"type": "integer", "minimum": 0},
    "max_attempts": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "available_at": {"type": "string", "format": "date-time"},
    "leased_by": {
      "type": ["string", "null"],
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,127}$"
    },
    "lease_expires_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "last_error_code": {
      "type": ["string", "null"],
      "pattern": "^[A-Z][A-Z0-9_]+$"
    },
    "last_error_message": {
      "type": ["string", "null"],
      "maxLength": 500
    },
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "completed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
