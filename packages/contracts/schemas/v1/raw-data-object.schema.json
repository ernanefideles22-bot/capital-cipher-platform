{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.capital-cipher.local/v1/raw-data-object.schema.json",
  "title": "Capital Cipher Raw Data Object v1",
  "type": "object",
  "required": [
    "schema_version",
    "object_hash",
    "object_uri",
    "content_type",
    "content_encoding",
    "uncompressed_bytes",
    "stored_bytes",
    "created_at"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "object_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "object_uri": {
      "type": "string",
      "pattern": "^lake://raw/[a-z0-9._/-]+\\.json\\.gz$"
    },
    "content_type": {"const": "application/json"},
    "content_encoding": {"const": "gzip"},
    "uncompressed_bytes": {"type": "integer", "minimum": 1},
    "stored_bytes": {"type": "integer", "minimum": 1},
    "created_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
