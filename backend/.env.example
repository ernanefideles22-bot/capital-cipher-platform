# Capital Cipher AI — PAPER default with explicitly gated TESTNET OMS.
# LIVE credentials and endpoints are prohibited. Sandbox credentials are
# injected only at runtime when TESTNET is explicitly enabled.
APP_ENV=local
SYSTEM_MODE=PAPER
DATABASE_URL=sqlite+aiosqlite:///./capital_cipher.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=0
DATABASE_POOL_TIMEOUT_SECONDS=15
DATABASE_POOL_RECYCLE_SECONDS=300

# OMS is PAPER by default. TESTNET is an exchange sandbox and requires an
# explicit enable flag plus the exact acknowledgement value documented below.
OMS_EXECUTION_ENVIRONMENT=PAPER
OMS_TESTNET_ENABLED=0
OMS_TESTNET_ACKNOWLEDGEMENT=
OMS_TESTNET_EXCHANGE=BINANCE
BINANCE_TESTNET_REST_URL=https://testnet.binance.vision
BYBIT_TESTNET_REST_URL=https://api-testnet.bybit.com
# Month 7 deliberately supports only Bybit one-way linear TESTNET.
BYBIT_TESTNET_CATEGORY=linear
OMS_HTTP_TIMEOUT_SECONDS=5
OMS_RECEIVE_WINDOW_MS=5000
OMS_WORKER_ENABLED=1
OMS_WORKER_POLL_INTERVAL_SECONDS=0.25
OMS_COMMAND_LEASE_SECONDS=15
OMS_RECONCILIATION_ENABLED=1
OMS_RECONCILIATION_INTERVAL_SECONDS=30
OMS_HALT_ON_CRITICAL_DRIFT=1

# TESTNET credentials are read directly from the process environment and are
# never loaded into Settings, stored in the database or returned by an API.
# Keep these blank in every source-controlled file.
CAPITAL_CIPHER_BINANCE_TESTNET_KEY_ID=
CAPITAL_CIPHER_BINANCE_TESTNET_SIGNING_SECRET=
CAPITAL_CIPHER_BYBIT_TESTNET_KEY_ID=
CAPITAL_CIPHER_BYBIT_TESTNET_SIGNING_SECRET=

# Leave REDIS_URL empty for the in-process bus. For local Redis, use:
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=
EVENT_BROKER_REQUIRED=0
REDIS_STREAM_PREFIX=capital-cipher
REDIS_STREAM_MAX_LENGTH=100000
BROKER_MAX_MESSAGE_BYTES=1000000
OUTBOX_POLL_INTERVAL_SECONDS=1.0
EVENT_PUBLICATION_MAX_CONCURRENCY=16

ENABLE_MARKET_DATA=0
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_RATE_LIMIT_PER_MINUTE=300
MAX_REQUEST_BODY_BYTES=2000000
ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
DEFAULT_TIMEFRAME=15m
DEFAULT_EXCHANGE=BINANCE

# Auth for every state-changing or resource-intensive endpoint.
# Generate at least 32 random characters. Empty means fail-closed.
ADMIN_API_KEY=

# Risk limits.
RISK_PER_TRADE_PERCENT=1.0
MAX_DAILY_DRAWDOWN_PERCENT=5.0
MAX_TOTAL_DRAWDOWN_PERCENT=10.0
MAX_CONSECUTIVE_LOSSES=3
MAX_OPEN_POSITIONS=3
DEFAULT_LEVERAGE=1.0
MAX_LEVERAGE_SIMULATED=5.0
MAX_GROSS_EXPOSURE_PERCENT=200
MAX_NET_EXPOSURE_PERCENT=150
MAX_SYMBOL_EXPOSURE_PERCENT=100
MAX_STRATEGY_EXPOSURE_PERCENT=100
MAX_SINGLE_POSITION_PERCENT=100
MAX_SYMBOL_CONCENTRATION_PERCENT=90
MAX_PORTFOLIO_VAR_PERCENT=5
VAR_CONFIDENCE=0.99
VAR_LOOKBACK=100
VAR_MIN_OBSERVATIONS=30
FALLBACK_VOLATILITY_PERCENT=1
RISK_APPROVAL_TTL_SECONDS=60
MAX_ENTRY_DEVIATION_BPS=100

# Paper trading.
PAPER_INITIAL_BALANCE=10000
FEE_RATE_PERCENT=0.08
SLIPPAGE_RATE_PERCENT=0.02
BACKTEST_HALF_SPREAD_BPS=1
BACKTEST_VOLUME_IMPACT_BPS=10
# Signed rate: positive means longs pay and shorts receive.
BACKTEST_FUNDING_RATE_BPS_PER_8H=0

# Decision engine.
MINIMUM_CANDIDATE_CONFIDENCE=70
PORTFOLIO_MAX_TARGET_WEIGHT_PERCENT=25

# Trusted clocks and bounded public historical imports.
REQUIRE_TRUSTED_MARKET_CLOCK=1
CLOCK_PROBE_INTERVAL_SECONDS=30
CLOCK_OBSERVATION_MAX_AGE_SECONDS=90
CLOCK_WARNING_OFFSET_MS=500
CLOCK_UNSAFE_OFFSET_MS=2000
CLOCK_WARNING_ROUND_TRIP_MS=1000
CLOCK_UNSAFE_ROUND_TRIP_MS=5000
HISTORICAL_BACKFILL_MAX_CANDLES=100000
PUBLIC_MARKET_HTTP_TIMEOUT_SECONDS=10
BINANCE_PUBLIC_REST_URL=https://data-api.binance.vision
BYBIT_PUBLIC_REST_URL=https://api.bybit.com

# Durable historical queue and private raw-object storage.
BACKFILL_WORKER_ENABLED=1
BACKFILL_WORKER_POLL_INTERVAL_SECONDS=1
BACKFILL_LEASE_SECONDS=3600
BACKFILL_MAX_ATTEMPTS=5
BACKFILL_RETRY_BASE_SECONDS=5
BACKFILL_RETRY_MAX_SECONDS=300
DATA_LAKE_ROOT=.capital-cipher-data-lake

# PAPER-only agent runtime. Attempts and leases are deliberately bounded.
AGENT_TIMEOUT_MS=5000
AGENT_MAX_ATTEMPTS=3
AGENT_MAX_CONCURRENCY=8
AGENT_WORKER_ENABLED=1
AGENT_WORKER_POLL_INTERVAL_SECONDS=0.25
AGENT_LEASE_SECONDS=30
AGENT_RETRY_BASE_SECONDS=0.05
AGENT_RETRY_MAX_SECONDS=0.2

# Month 10 operational control plane. It observes PAPER workloads only and
# cannot submit, cancel or approve orders.
OPERATIONS_MONITOR_ENABLED=1
OPERATIONS_MONITOR_INTERVAL_SECONDS=30
OPERATIONS_METRIC_CAPACITY=10000
OPERATIONS_WINDOW_SECONDS=300
OPERATIONS_DAILY_BUDGET_USD=10
OPERATIONS_BUDGET_WARNING_PERCENT=80
AGENT_EXECUTION_UNIT_COST_USD=0
AGENT_SUCCESS_SLO=0.99
AGENT_P95_LATENCY_SLO_MS=2000
ORCHESTRATOR_SUCCESS_SLO=0.99
ORCHESTRATOR_P95_LATENCY_SLO_MS=5000
RECOVERY_SUCCESSES_REQUIRED=3
